<Window x:Class="BingoGUI_PanczelCsenge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BingoGUI_PanczelCsenge"
        mc:Ignorable="d"
        Title="MainWindow" Height="250" Width="150">
    <Grid>
        <StackPanel HorizontalAlignment="Center" Margin="10">

            <Button Name="btnGeneral"
                    Content="Kártya generálása"
                    Click="btnGeneral_Click"
                    Margin="5"/>

            <Grid Name="gridKartya"
                  Margin="5"/>

            <TextBox Name="txtFajlNev"
                     Text="bingo.txt"
                     Margin="5"/>

            <Button Name="btnMentes"
                    Content="Mentés"
                    Click="btnMentes_Click"
                    Margin="5"/>

        </StackPanel>
    </Grid>
</Window>
