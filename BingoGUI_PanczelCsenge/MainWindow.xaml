<Window x:Class="BingoGUI_PanczelCsenge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BingoGUI_PanczelCsenge"
        mc:Ignorable="d"
        Title="MainWindow" Height="250" Width="150">
  <Grid Margin="10">

    <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>  
        <RowDefinition Height="*"/>     
        <RowDefinition Height="Auto"/>  
        <RowDefinition Height="Auto"/>  
    </Grid.RowDefinitions>

    <Button Name="btnGeneral"
            Content="Kártya generálása"
            Click="btnGeneral_Click"
            Margin="5"
            Grid.Row="0"/>

    <Grid Name="gridKartya"
          Margin="5"
          Grid.Row="1"/>

    <TextBox Name="txtFajlNev"
             Text="bingo.txt"
             Margin="5"
             Grid.Row="2"/>

    <Button Name="btnMentes"
            Content="Mentés"
            Click="btnMentes_Click"
            Margin="5"
            Grid.Row="3"/>

</Grid>
</Window>
